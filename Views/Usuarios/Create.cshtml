@model PruebaDesempeño.Models.Usuario


<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12">
            <h2>Crear Usuario</h2>
        </div>
    </div>
    @if (TempData["message"] != null)
    {
        <div class="alert alert-@TempData["status"]">
            @TempData["message"]
        </div>
    }

    <div class="row">
        <div class="col-md-6">

            <form asp-controller="Usuarios" asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Documento de identidad</label>
                    <input asp-for="DocumentoIdentidad" class="form-control" />
                    <span asp-validation-for="DocumentoIdentidad" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Correo</label>
                    <input asp-for="Correo" class="form-control" />
                    <span asp-validation-for="Correo" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        Guardar
                    </button>

                    <a asp-controller="Usuarios" asp-action="Index" class="btn btn-secondary">
                        Cancelar
                    </a>
                </div>

            </form>

        </div>
    </div>

</div>