@model IEnumerable<PruebaDesempeño.Models.EspacioDeportivo>

<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>Lista de Espacios Deportivos</h2>
            <a class="btn btn-success" asp-controller="EspacioDeportivo" asp-action="Create">Crear</a>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <table class="table table-striped table-bordered align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Tipo de Espacio</th>
                        <th>Capacidad</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Id</td>
                        <td>@e.Nombre</td>
                        <td>@e.TipoEspacio</td>
                        <td>@e.capacidad</td>
                        <td class="text-end">
                            <a class="btn btn-outline-warning btn-sm"
                               asp-controller="EspacioDeportivo"
                               asp-action="Update"
                               asp-route-id="@e.Id">
                                Editar
                            </a>

                            <form asp-controller="EspacioDeportivo"
                                  asp-action="Delete"
                                  asp-route-id="@e.Id"
                                  method="post"
                                  class="d-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

</div>