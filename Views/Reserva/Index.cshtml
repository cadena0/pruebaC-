@model IEnumerable<PruebaDesempeño.Models.Reservas>

<div class="container mt-4">

    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>Lista de Reservas</h2>
            <a class="btn btn-success"
               asp-controller="Reserva"
               asp-action="Create">
                Crear
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <table class="table table-striped table-bordered align-middle">
                <thead class="table-dark text-center">
                    <tr>
                        <th>ID</th>
                        <th>Usuario</th>
                        <th>Espacio Deportivo</th>
                        <th>Fecha</th>
                        <th>Hora de Inicio</th>
                        <th>Hora de fin</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.UsuariosId</td>
                        <td>@r.EspacioDeportivoId</td>
                        <td>@r.Fecha</td>
                        <td>@r.horaInicio</td>
                        <td>@r.horaFim</td>

                        <td class="text-end">

                            <a class="btn btn-outline-warning btn-sm"
                               asp-controller="Reserva"
                               asp-action="Update"
                               asp-route-id="@r.Id">
                                Editar
                            </a>

                            <form asp-controller="Reserva"
                                  asp-action="Delete"
                                  asp-route-id="@r.Id"
                                  method="post"
                                  class="d-inline">

                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm">
                                    Eliminar
                                </button>

                            </form>

                        </td>
                    </tr>
                }
                </tbody>

            </table>

        </div>
    </div>

</div>